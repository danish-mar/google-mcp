# Server
HOST=127.0.0.1
PORT=8080

# Internal service ports (no need to expose these externally)
YOUTUBE_MCP_PORT=8081
MAPS_MCP_PORT=8082
CALENDAR_MCP_PORT=8083
GMAIL_MCP_PORT=8084

# ── Google API Keys (API key-based services) ─────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=
MAPS_API_KEY=

# ── Google OAuth2 (for Calendar & Gmail) ────────────────────────────────────
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Desktop app or Web app)
# 3. Enable Calendar API and Gmail API in the console
# 4. Run: node scripts/oauth-setup.js  (or follow README for manual token exchange)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_GMAIL_REFRESH_TOKEN=

# ── MCP Endpoint Auth (optional) ─────────────────────────────────────────────
# If set, all /mcp/* endpoints require:  Authorization: Bearer <token>
# Leave empty to keep MCP endpoints open (useful for local dev)
MCP_ACCESS_TOKEN=

# ── WebUI Auth ───────────────────────────────────────────────────────────────
WEBUI_TITLE=Google MCP Control Center
WEBUI_PASSWORD=change-me
WEBUI_SESSION_SECRET=replace-this-session-secret
