<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %> | <%= webUiTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              accent: "#14532d",
              glow: "#f59e0b",
              shell: "#f6f5ef",
              ink: "#111827",
            },
            boxShadow: {
              panel: "0 24px 80px rgba(17, 24, 39, 0.12)",
            },
          },
        },
      };
    </script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
  </head>
  <body class="min-h-screen bg-shell text-ink">
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute left-0 top-0 h-72 w-72 rounded-full bg-amber-200/60 blur-3xl"></div>
      <div class="absolute right-0 top-24 h-96 w-96 rounded-full bg-emerald-200/70 blur-3xl"></div>
      <div class="absolute bottom-0 left-1/3 h-80 w-80 rounded-full bg-lime-100 blur-3xl"></div>
    </div>

    <header class="border-b border-black/5 bg-white/60 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-black/50">FastMCP WebUI</p>
          <h1 class="font-serif text-2xl"><%= webUiTitle %></h1>
        </div>

        <div class="flex items-center gap-3 text-sm">
          <a
            class="rounded-full border border-black/10 px-4 py-2 transition hover:border-accent hover:text-accent"
            href="/dashboard"
          >
            <i class="fa-solid fa-chart-line"></i>
            Dashboard
          </a>
          <a
            class="rounded-full border border-black/10 px-4 py-2 transition hover:border-accent hover:text-accent"
            href="/health"
          >
            <i class="fa-solid fa-heart-pulse"></i>
            Health
          </a>
          <% if (activePath === "/dashboard" || activePath === "/settings" || activePath === "/configure") { %>
          <a
            class="rounded-full border border-black/10 px-4 py-2 transition hover:border-accent hover:text-accent"
            href="/configure"
          >
            <i class="fa-solid fa-key"></i>
            Configure
          </a>
          <a
            class="rounded-full border border-black/10 px-4 py-2 transition hover:border-accent hover:text-accent"
            href="/settings"
          >
            <i class="fa-solid fa-gear"></i>
            Settings
          </a>
          <form action="/logout" method="post">
            <button
              class="rounded-full bg-ink px-4 py-2 text-white transition hover:bg-accent"
              type="submit"
            >
              <i class="fa-solid fa-right-from-bracket"></i>
              Logout
            </button>
          </form>
          <% } %>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-6 py-10">
      <%- content %>
    </main>
  </body>
</html>
