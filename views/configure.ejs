<section class="mx-auto max-w-3xl space-y-8">
  <div class="rounded-[2rem] border border-black/10 bg-white/80 p-8 shadow-panel backdrop-blur">
    <div class="mb-6">
      <h2 class="text-3xl font-semibold">Service Configuration</h2>
      <p class="mt-2 text-black/60">Manage your API keys and tokens. Changes here are saved dynamically to <code>data/runtime-config.json</code> and apply immediately without requiring a restart.</p>
    </div>

    <% if (saveMessage) { %>
    <div class="mb-6 rounded-2xl bg-emerald-100 px-5 py-4 text-emerald-800">
      <i class="fa-solid fa-circle-check mr-2"></i> <%= saveMessage %>
    </div>
    <% } %>

    <form action="/configure" method="post" class="space-y-8">
      
      <!-- API Keys Section -->
      <div class="space-y-4">
        <h3 class="text-xl font-medium border-b border-black/10 pb-2">API Keys</h3>
        
        <div>
          <label class="block text-sm font-medium text-black/80" for="youtubeApiKey">YouTube API Key</label>
          <input
            class="mt-1 block w-full rounded-xl border border-black/20 bg-white px-4 py-2 font-mono text-sm placeholder:text-black/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            id="youtubeApiKey"
            name="youtubeApiKey"
            type="password"
            value="<%= serviceConfig.youtubeApiKey %>"
            placeholder="AIzaSy..."
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-black/80" for="mapsApiKey">Google Maps API Key</label>
          <input
            class="mt-1 block w-full rounded-xl border border-black/20 bg-white px-4 py-2 font-mono text-sm placeholder:text-black/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            id="mapsApiKey"
            name="mapsApiKey"
            type="password"
            value="<%= serviceConfig.mapsApiKey %>"
            placeholder="AIzaSy..."
          />
        </div>
      </div>

      <!-- OAuth2 Section -->
      <div class="space-y-4">
        <h3 class="text-xl font-medium border-b border-black/10 pb-2">OAuth2 Credentials</h3>
        <p class="text-xs text-black/50">Required for Calendar, Gmail, and Contacts. Get these from Google Cloud Console.</p>
        
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-black/80" for="googleClientId">Client ID</label>
            <input
              class="mt-1 block w-full rounded-xl border border-black/20 bg-white px-4 py-2 font-mono text-sm placeholder:text-black/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              id="googleClientId"
              name="googleClientId"
              type="text"
              value="<%= serviceConfig.googleClientId %>"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-black/80" for="googleClientSecret">Client Secret</label>
            <input
              class="mt-1 block w-full rounded-xl border border-black/20 bg-white px-4 py-2 font-mono text-sm placeholder:text-black/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              id="googleClientSecret"
              name="googleClientSecret"
              type="password"
              value="<%= serviceConfig.googleClientSecret %>"
            />
          </div>
        </div>

        <% if (serviceConfig.googleClientId && serviceConfig.googleClientSecret) { %>
        <div class="rounded-xl border border-black/10 bg-black/5 p-5 flex items-center justify-between">
          <div>
            <h4 class="font-medium">Automatic Setup</h4>
            <p class="text-xs text-black/60 mt-1">Sign in with Google to automatically generate refresh tokens.</p>
          </div>
          <a
            href="/oauth/start"
            class="rounded-xl bg-white px-4 py-2 font-medium text-black border border-black/10 shadow-sm hover:bg-black/5 transition flex items-center gap-2"
          >
            <i class="fa-brands fa-google text-blue-500"></i>
            Sign in with Google
          </a>
        </div>
        <% } else { %>
        <div class="rounded-xl border border-amber-200 bg-amber-50 p-5">
          <p class="text-sm text-amber-800">
            <i class="fa-solid fa-triangle-exclamation mr-1"></i>
            Save your Client ID and Client Secret first to enable automatic Google Sign-in.
            Make sure your redirect URI in Cloud Console is set to: <code class="font-mono bg-white/50 px-1 rounded">http://127.0.0.1:<%= appConfig.port %>/oauth/callback</code>
          </p>
        </div>
        <% } %>

        <div>
          <label class="block text-sm font-medium text-black/80" for="googleCalendarRefreshToken">Calendar Refresh Token</label>
          <input
            class="mt-1 block w-full rounded-xl border border-black/20 bg-white px-4 py-2 font-mono text-sm placeholder:text-black/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            id="googleCalendarRefreshToken"
            name="googleCalendarRefreshToken"
            type="password"
            value="<%= serviceConfig.googleCalendarRefreshToken %>"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-black/80" for="googleGmailRefreshToken">Gmail Refresh Token</label>
          <input
            class="mt-1 block w-full rounded-xl border border-black/20 bg-white px-4 py-2 font-mono text-sm placeholder:text-black/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            id="googleGmailRefreshToken"
            name="googleGmailRefreshToken"
            type="password"
            value="<%= serviceConfig.googleGmailRefreshToken %>"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-black/80" for="googleContactsRefreshToken">Contacts Refresh Token</label>
          <input
            class="mt-1 block w-full rounded-xl border border-black/20 bg-white px-4 py-2 font-mono text-sm placeholder:text-black/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            id="googleContactsRefreshToken"
            name="googleContactsRefreshToken"
            type="password"
            value="<%= serviceConfig.googleContactsRefreshToken %>"
          />
        </div>
      </div>

      <!-- Security Section -->
      <div class="space-y-4">
        <h3 class="text-xl font-medium border-b border-black/10 pb-2">MCP Security</h3>
        
        <div>
          <label class="block text-sm font-medium text-black/80" for="mcpAccessToken">MCP Access Token (Optional)</label>
          <p class="text-xs text-black/50 mb-1">If set, clients must send <code>Authorization: Bearer &lt;token&gt;</code> to access endpoints.</p>
          <input
            class="mt-1 block w-full rounded-xl border border-black/20 bg-white px-4 py-2 font-mono text-sm placeholder:text-black/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            id="mcpAccessToken"
            name="mcpAccessToken"
            type="password"
            value="<%= serviceConfig.mcpAccessToken %>"
          />
        </div>
      </div>

      <div class="pt-4">
        <button
          class="w-full rounded-2xl bg-accent px-6 py-3 font-medium text-white transition hover:bg-emerald-800"
          type="submit"
        >
          Save Configuration
        </button>
      </div>
    </form>
  </div>
</section>
